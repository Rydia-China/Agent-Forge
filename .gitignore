# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# FC functions (actual implementations managed separately)
FC/**/node_modules/
FC/**/package-lock.json
FC/**/.env
!FC/**/.env.example
FC/**/.s/
# FC deployment configs with secrets
FC/**/s.yaml
!FC/**/s.yaml.example

# prisma generated client
src/generated

# debug logs

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
agent-forge.tar.gz

# database backups
/backups/

# local SQLite indexes
/db/

# runtime logs
logs/
dev.log

# git worktrees (managed by `git worktree`)
.agent-worktrees/

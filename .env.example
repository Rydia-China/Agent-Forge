PORT=8001

# 数据库连接
# docker compose -f docker-compose.dev.yml up -d 启动开发数据库
DATABASE_URL=postgresql://postgres:12345678@localhost:5432/agent_forge

# 业务数据库 — 同实例不同 database（用户业务数据）
BUSINESS_DATABASE_URL=postgresql://postgres:12345678@localhost:5432/biz

# LLM（OpenAI-compatible）
LLM_API_KEY=
LLM_BASE_URL=https://ai.mob-ai.cn/api/v1
LLM_DEFAULT_MODEL=deepseek-v4-pro
# enabled | disabled | provider-default
LLM_THINKING_MODE=disabled

# 标题生成模型（可选，默认用主控模型）
LLM_TITLE_MODEL=

# 图片生成走 mob-ai-router /api/v1/generations，复用 LLM_BASE_URL 和 LLM_API_KEY

# 视频生成（Seedance）
FC_GENERATE_VIDEO_URL=
FC_GENERATE_VIDEO_TOKEN=

# 视频最后一帧提取（当 FC_GENERATE_VIDEO_URL 未直接返回 lastFrameUrl 时使用）
FC_EXTRACT_LAST_FRAME_URL=
FC_EXTRACT_LAST_FRAME_TOKEN=

# 外部分发 API keys（只用于 /api/external/video/*，不影响 chat/MCP/agent）
# 支持两种格式：
# EXTERNAL_VIDEO_API_KEYS=customer-a:secret-a,customer-b:secret-b
# EXTERNAL_VIDEO_API_KEYS=[{"name":"customer-a","key":"secret-a"},{"name":"customer-b","key":"secret-b"}]
EXTERNAL_VIDEO_API_KEYS=

# 视频裁剪
FC_CROP_VIDEO_URL=
FC_CROP_VIDEO_TOKEN=

# 视频拼接
FC_CONCAT_CLIPS_URL=
FC_CONCAT_CLIPS_TOKEN=

# HappyHorse 视频生成（支持文生视频和多参考图生视频）
FC_HAPPYHORSE_URL=
FC_HAPPYHORSE_TOKEN=

# OSS（阿里云对象存储）
OSS_REGION=cn-shanghai
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=
OSS_ENDPOINT=https://oss-cn-shanghai.aliyuncs.com


# Langfuse（prompt 管理）
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=

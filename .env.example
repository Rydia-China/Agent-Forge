PORT=8001

# 数据库连接
# docker compose -f docker-compose.dev.yml up -d 启动开发数据库
DATABASE_URL=postgresql://postgres:12345678@localhost:5432/agent_forge

# 业务数据库 — 同实例不同 database（用户业务数据）
BUSINESS_DATABASE_URL=postgresql://postgres:12345678@localhost:5432/biz

# LLM（OpenAI-compatible）
LLM_API_KEY=
LLM_BASE_URL=https://zenmux.ai/api/v1

# 标题生成模型
LLM_TITLE_MODEL=

# Executor 子代理模型（默认 x-ai/grok-code-fast-1）
EXECUTOR_MODEL=

# FC 函数（图片生成，与 video-mgr 共用）
FC_GENERATE_IMAGE_URL=
FC_GENERATE_IMAGE_TOKEN=

# Seedance 2.0 视频生成 API（BytePlus Ark）
SEEDANCE_ARK_BASE_URL=https://ark.ap-southeast.bytepluses.com
SEEDANCE_ARK_API_KEY=

# OSS（阿里云对象存储，与 video-mgr 共用）
OSS_REGION=cn-shanghai
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=
OSS_ENDPOINT=https://oss-cn-shanghai.aliyuncs.com

# Novel Service（远程小说服务）
NOVEL_SERVICE_URL=http://47.98.225.71:8092

# Langfuse（prompt 管理）
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=

# Forge Sync（hub-spoke 同步）
FORGE_HUB_URL=https://agent.mob-ai.cn/
FORGE_IS_HUB=false

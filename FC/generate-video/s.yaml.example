edition: 3.0.0
name: fc3-example
access: default
resources:
  fcDemo:
    component: fc3
    props:
      region: cn-hangzhou
      handler: index.handler
      role: ''
      disableOndemand: false
      description: ''
      timeout: 300
      diskSize: 512
      internetAccess: true
      resourceGroupId: rg-acfmwcye2ca5jca
      instanceIsolationMode: SHARE
      logConfig:
        enableRequestMetrics: true
        enableInstanceMetrics: true
        logBeginRule: DefaultRegex
        project: serverless-cn-hangzhou-be4c408d-7f9d-59bc-9f0e-3de9dd268c6d
        logstore: default-logs
      functionName: generate-video
      sessionAffinity: NONE
      runtime: nodejs18
      cpu: 0.1
      memorySize: 256
      environmentVariables:
        OSS_ACCESS_KEY_ID: YOUR_OSS_ACCESS_KEY_ID
        OSS_BUCKET: your-bucket-name
        OSS_REGION: cn-shanghai
        OSS_ACCESS_KEY_SECRET: YOUR_OSS_ACCESS_KEY_SECRET
        JIMENG_ACCESS_KEY_ID: YOUR_JIMENG_ACCESS_KEY_ID
        JIMENG_SECRET_ACCESS_KEY: YOUR_JIMENG_SECRET_ACCESS_KEY
        OSS_ENDPOINT: https://oss-cn-shanghai.aliyuncs.com
        BYTEPLUS_ACCESS_KEY_ID: YOUR_BYTEPLUS_ACCESS_KEY_ID
        BYTEPLUS_SECRET_ACCESS_KEY: YOUR_BYTEPLUS_SECRET_ACCESS_KEY
        BYTEPLUS_REGION: ap-southeast-1
        BYTEPLUS_PROJECT_NAME: default
        BYTEPLUS_ASSET_GROUP_NAME_PREFIX: agent-forge-video
        ARK_API_KEY: YOUR_ARK_API_KEY
        ARK_BASE_URL: https://ark.ap-southeast.bytepluses.com/api/v3
        ARK_CONTENT_GENERATION_TASKS_PATH: /contents/generations/tasks
        SEEDANCE_MODEL: dreamina-seedance-2-0-260128
        SEEDANCE_RATIO: adaptive
        SEEDANCE_RESOLUTION: 720p
        SEEDANCE_WATERMARK: 'false'
        SEEDANCE_GENERATE_AUDIO: 'false'
      code: ./generate-video
      triggers:
        - triggerConfig:
            methods:
              - POST
              - OPTIONS
            authType: bearer
            disableURLInternet: false
            authConfig:
              bearerFormat: opaque
              opaqueTokenConfig:
                tokens:
                  - createdTime: '2026-01-11T13:22:41Z'
                    enable: true
                    lastModifiedTime: '2026-01-11T13:22:41Z'
                    tokenData: YOUR_TOKEN_DATA
                    tokenID: YOUR_TOKEN_ID
                    tokenName: YOUR_TOKEN_NAME
          triggerName: defaultTrigger
          description: ''
          qualifier: LATEST
          triggerType: http
      scalingConfig:
        minInstances: 1

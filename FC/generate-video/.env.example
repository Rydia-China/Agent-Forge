# OSS配置 (必需)
OSS_REGION=cn-hangzhou
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=
OSS_ENDPOINT=

# 即梦 API 配置 (必需)
JIMENG_ACCESS_KEY_ID=
JIMENG_SECRET_ACCESS_KEY=

# BytePlus Ark Assets API 配置 (必需，用于将图片 URL 注册为 asset:// 资源)
BYTEPLUS_ACCESS_KEY_ID=
BYTEPLUS_SECRET_ACCESS_KEY=
BYTEPLUS_REGION=ap-southeast-1
BYTEPLUS_PROJECT_NAME=default
BYTEPLUS_ASSET_GROUP_NAME_PREFIX=agent-forge-video
BYTEPLUS_ASSET_READY_TIMEOUT_MS=120000
BYTEPLUS_ASSET_READY_INTERVAL_MS=3000

# ModelArk Seedance 2.0 运行时配置
# 推荐配置 ARK_API_KEY；也可配置 ARK_ENDPOINT_ID 并授予 AK/SK ark:GetApiKey 权限，让函数自动换临时 key。
ARK_API_KEY=
ARK_ENDPOINT_ID=
ARK_API_KEY_TTL_SECONDS=3600
ARK_BASE_URL=https://ark.ap-southeast.bytepluses.com/api/v3
ARK_CONTENT_GENERATION_TASKS_PATH=/contents/generations/tasks
SEEDANCE_MODEL=dreamina-seedance-2-0-260128
SEEDANCE_RATIO=9:16
SEEDANCE_RESOLUTION=720p
SEEDANCE_WATERMARK=false
SEEDANCE_POLL_MAX_RETRIES=120
SEEDANCE_POLL_INTERVAL_MS=5000

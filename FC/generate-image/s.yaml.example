edition: 3.0.0
name: fc3-example
access: default
resources:
  fcDemo:
    component: fc3
    props:
      region: cn-hangzhou
      handler: index.handler
      role: ''
      disableOndemand: false
      description: ''
      timeout: 600
      diskSize: 512
      internetAccess: true
      resourceGroupId: rg-acfmwcye2ca5jca
      instanceIsolationMode: SHARE
      logConfig:
        enableRequestMetrics: true
        enableInstanceMetrics: true
        logBeginRule: DefaultRegex
        project: serverless-cn-hangzhou-be4c408d-7f9d-59bc-9f0e-3de9dd268c6d
        logstore: default-logs
      functionName: generate-image
      sessionAffinity: NONE
      runtime: nodejs18
      cpu: 0.1
      memorySize: 256
      environmentVariables:
        OSS_ACCESS_KEY_ID: YOUR_OSS_ACCESS_KEY_ID
        OSS_BUCKET: your-bucket-name
        OSS_REGION: cn-shanghai
        OSS_ACCESS_KEY_SECRET: YOUR_OSS_ACCESS_KEY_SECRET
        GEMINI_API_KEY: YOUR_GEMINI_API_KEY
        GEMINI_MODEL: google/gemini-3.1-flash-image-preview
        OSS_ENDPOINT: https://oss-cn-shanghai.aliyuncs.com
        GEMINI_BASE_URL: https://zenmux.ai/api/v1
      code: ./generate-image
      triggers:
        - triggerConfig:
            methods:
              - POST
              - OPTIONS
            authType: bearer
            disableURLInternet: false
            authConfig:
              bearerFormat: opaque
              opaqueTokenConfig:
                tokens:
                  - createdTime: '2026-01-11T11:18:15Z'
                    enable: true
                    lastModifiedTime: '2026-01-11T11:18:15Z'
                    tokenData: YOUR_TOKEN_DATA
                    tokenID: YOUR_TOKEN_ID
                    tokenName: YOUR_TOKEN_NAME
          triggerName: main
          description: ''
          qualifier: LATEST
          triggerType: http
      asyncInvokeConfig:
        asyncTask: true
        maxAsyncEventAgeInSeconds: 86400
        destinationConfig: {}
        maxAsyncRetryAttempts: 3

edition: 3.0.0
name: generate-image-gpt
access: default
resources:
  fcGPT:
    component: fc3
    props:
      region: cn-hangzhou
      handler: index.handler
      role: ''
      disableOndemand: false
      description: 'GPT Image Generation Function'
      timeout: 600
      diskSize: 512
      internetAccess: true
      resourceGroupId: rg-acfmwcye2ca5jca
      instanceIsolationMode: SHARE
      logConfig:
        enableRequestMetrics: true
        enableInstanceMetrics: true
        logBeginRule: DefaultRegex
        project: serverless-cn-hangzhou-be4c408d-7f9d-59bc-9f0e-3de9dd268c6d
        logstore: default-logs
      functionName: generate-image-gpt
      sessionAffinity: NONE
      runtime: nodejs18
      cpu: 0.1
      memorySize: 256
      environmentVariables:
        OSS_ACCESS_KEY_ID: YOUR_OSS_ACCESS_KEY_ID
        OSS_BUCKET: your-bucket-name
        OSS_REGION: us-west-1
        OSS_ACCESS_KEY_SECRET: YOUR_OSS_ACCESS_KEY_SECRET
        OSS_ENDPOINT: https://oss-us-west-1.aliyuncs.com
        GPT_IMAGE2_BASE_URL: https://mm-internal-cn.leonecloud.com
        GPT_IMAGE2_TOKEN: YOUR_GPT_IMAGE2_TOKEN
      code: .
      triggers:
        - triggerConfig:
            methods:
              - POST
              - OPTIONS
            authType: bearer
            disableURLInternet: false
            authConfig:
              bearerFormat: opaque
              opaqueTokenConfig:
                tokens:
                  - createdTime: '2026-04-23T10:18:00Z'
                    enable: true
                    lastModifiedTime: '2026-04-23T10:18:00Z'
                    tokenData: YOUR_TOKEN_DATA
                    tokenID: YOUR_TOKEN_ID
                    tokenName: YOUR_TOKEN_NAME
          triggerName: main
          description: 'HTTP trigger for GPT image generation'
          qualifier: LATEST
          triggerType: http
      asyncInvokeConfig:
        asyncTask: true
        maxAsyncEventAgeInSeconds: 86400
        maxAsyncRetryAttempts: 3
      scalingConfig:
        minInstances: 1

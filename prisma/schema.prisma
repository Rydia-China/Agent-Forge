generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Skill — 遵循 Agent Skills 开放标准 (agentskills.io)
/// 实体表只保留身份字段 + production 指针，内容存在 SkillVersion
model Skill {
  id                String         @id @default(cuid())
  name              String         @unique
  tags              String[]
  productionVersion Int            @default(1)
  versions          SkillVersion[]
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
}

/// SkillVersion — 不可变的版本快照
model SkillVersion {
  id          String   @id @default(cuid())
  skillId     String
  skill       Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)
  version     Int
  description String
  content     String
  metadata    Json?
  createdAt   DateTime @default(now())

  @@unique([skillId, version])
  @@index([skillId])
}

/// User — 轻量用户标识，无密码，按 name 区分
model User {
  id       String        @id @default(cuid())
  name     String        @unique
  sessions ChatSession[]
}

/// ChatSession — 对话会话，持久化多轮对话，按 user 隔离
model ChatSession {
  id           String         @id @default(cuid())
  title        String?
  userId       String
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages         ChatMessage[]
  subagents        SubAgent[]
  imageGenerations ImageGeneration[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([userId])
}

/// ChatMessage — 单条对话消息
model ChatMessage {
  id         String      @id @default(cuid())
  sessionId  String
  session    ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role       String      // "user" | "assistant" | "tool"
  content    String?
  images     String[]    // 附带的图片 URL 列表（视觉模型用）
  toolCalls  Json?       // OpenAI tool_calls 数组
  toolCallId String?
  hidden     Boolean     @default(false)
  createdAt  DateTime    @default(now())

  @@index([sessionId, createdAt])
}

/// KeyResource — 关键资源，版本化，scope-based（novel / script）
/// scopeType + scopeId 决定归属，key 在 scope 内唯一
model KeyResource {
  id             String               @id @default(cuid())
  scopeType      String               // "novel" | "script"
  scopeId        String               // novel ID / script DB ID
  key            String
  mediaType      String               // "image" | "video" | "json"
  category       String?              // UI grouping: 角色立绘, 场景, 换装, 视频
  title          String?              // Display name: character name, scene name, etc.
  currentVersion Int                  @default(0)
  versions       KeyResourceVersion[]
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@unique([scopeType, scopeId, key])
  @@index([scopeType, scopeId])
}

/// KeyResourceVersion — 不可变的版本快照
model KeyResourceVersion {
  id            String      @id @default(cuid())
  keyResourceId String
  keyResource   KeyResource @relation(fields: [keyResourceId], references: [id], onDelete: Cascade)
  version       Int
  title         String?
  url           String?
  data          Json?
  prompt        String?
  refUrls       String[]
  createdAt     DateTime    @default(now())

  @@unique([keyResourceId, version])
  @@index([keyResourceId])
}

/// ImageGeneration — 图片生成实体，session 级别
/// 主记录只保留身份 + 指针，所有可变数据存 ImageGenerationVersion
model ImageGeneration {
  id              String                   @id @default(cuid())
  sessionId       String
  session         ChatSession              @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  key             String                   // LLM 指定的语义 key，session 内唯一
  currentVersion  Int                      @default(0)
  versions        ImageGenerationVersion[]
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  @@unique([sessionId, key])
  @@index([sessionId])
}

/// ImageGenerationVersion — 不可变的版本快照
model ImageGenerationVersion {
  id         String          @id @default(cuid())
  imageGenId String
  imageGen   ImageGeneration @relation(fields: [imageGenId], references: [id], onDelete: Cascade)
  version    Int
  prompt     String
  imageUrl   String?         // 生成完成前为 null
  refUrls    String[]
  createdAt  DateTime        @default(now())

  @@unique([imageGenId, version])
  @@index([imageGenId])
}

/// StylePreset — 本地风格提示词预设，替代 Langfuse 风格词获取
/// 存储纯风格词 + 可选参考图，通过 MCP tools 暴露给 agent
model StylePreset {
  id                String   @id @default(cuid())
  name              String   @unique
  prompt            String
  referenceImageUrl String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

/// BizTableMapping — 逻辑表名到物理表名(UUID)的映射，实现 biz-db 用户隔离
/// userName="_global_" 表示全局表，其他值为用户私有表
model BizTableMapping {
  id           String   @id @default(cuid())
  userName     String
  logicalName  String
  physicalName String   @unique
  createdAt    DateTime @default(now())

  @@unique([userName, logicalName])
  @@index([userName])
}

/// SubAgent — 统一的执行单元，支持单次执行和多轮工具调用，可嵌套
/// 替代原 Task 模型，提供完整的 trace 和嵌套能力
model SubAgent {
  id            String          @id @default(cuid())
  sessionId     String
  session       ChatSession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  parentAgentId String?         // 父 agent ID（嵌套时）
  parent        SubAgent?       @relation("SubAgentHierarchy", fields: [parentAgentId], references: [id], onDelete: Cascade)
  children      SubAgent[]      @relation("SubAgentHierarchy")
  depth         Int             @default(0) // 嵌套深度（0 = 顶层）
  status        String          @default("pending") // pending | running | completed | failed | cancelled | max_iterations
  config        Json            // SubAgentConfig（instruction, mcpScope, model, etc.）
  output        String?         // 最终输出
  error         String?         // 错误信息
  trace         Json?           // SubAgentTrace（完整执行轨迹）
  events        SubAgentEvent[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([sessionId, status])
  @@index([parentAgentId])
}

/// SubAgentEvent — 可重放的事件流，autoincrement id 用于 Last-Event-ID 排序
model SubAgentEvent {
  id         Int      @id @default(autoincrement())
  subagentId String
  subagent   SubAgent @relation(fields: [subagentId], references: [id], onDelete: Cascade)
  type       String   // delta | tool_start | tool_end | child_spawn | done | error | session | upload_request | key_resource
  data       Json
  createdAt  DateTime @default(now())

  @@index([subagentId, id])
}

/// BizSchema — biz-db 表结构的声明式注册表（版本化）
/// 实体表保留逻辑表名 + production 指针，结构存在 BizSchemaVersion
model BizSchema {
  id                String             @id @default(cuid())
  tableName         String             @unique
  productionVersion Int                @default(1)
  versions          BizSchemaVersion[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

/// BizSchemaVersion — 不可变的表结构快照
model BizSchemaVersion {
  id          String    @id @default(cuid())
  bizSchemaId String
  bizSchema   BizSchema @relation(fields: [bizSchemaId], references: [id], onDelete: Cascade)
  version     Int
  columns     Json      /// [{ name, type, nullable?, default? }]
  constraints Json?     /// [{ type: "pk"|"unique", columns: string[] }]
  description String?
  createdAt   DateTime  @default(now())

  @@unique([bizSchemaId, version])
  @@index([bizSchemaId])
}


